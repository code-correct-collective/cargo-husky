{
   "$schema": "https://raw.githubusercontent.com/code-correct-collective/cargo-husky/refs/heads/main/schema.json",
   "tasks": [
      {
         "name": "welcome-message-example",
         "command": "echo",
         "args": [ "Cargo Husky is awesome!" ]
      },
      {
         "name": "cargo-check",
         "group": "pre-commit",
         "command": "cargo",
         "args": [ "check" ],
         "include": ["*.rs"]
      },
      {
         "name": "cargo-clippy",
         "group": "pre-commit",
         "command": "cargo",
         "args": [ "clippy", "--", "-Dwarnings" ],
         "include": ["*.rs", "*.toml"]
      },
      {
         "name": "cargo-fmt-verify",
         "group": "pre-commit",
         "command": "cargo",
         "args": [ "fmt", "--all", "--check" ],
         "include": ["*.rs"]
      },
      {
         "name": "cargo-test",
         "group": "pre-push",
         "command": "cargo",
         "args": [ "test" ],
         "include": ["*.rs"]
      },
      {
         "name": "cargo-audit",
         "group": "pre-push",
         "command": "cargo",
         "args": [ "audit" ],
         "include": ["Cargo.toml", "Cargo.lock"]
      }
   ]
}
